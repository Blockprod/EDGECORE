# Trading Engine Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=production
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_CONSOLE_LEVEL=WARNING

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_JSON_FORMAT=true
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=7

# ============================================================================
# Caching Configuration
# ============================================================================
ENABLE_DASHBOARD_CACHE=true
CACHE_MAX_SIZE=100
CACHE_DEFAULT_TTL=30
CACHE_SYSTEM_TTL=10
CACHE_RISK_TTL=30
CACHE_PERF_TTL=60

# ============================================================================
# API Configuration
# ============================================================================
FLASK_ENV=production
FLASK_WORKERS=4
MONITORING_PORT=5000
API_RATE_LIMIT_RPM=600
API_KEY_REQUIRED=true
REQUIRE_HTTPS=false

# ============================================================================
# Exchange (CCXT)
# ============================================================================
CCXT_EXCHANGE=binance
CCXT_API_KEY=REPLACE_WITH_YOUR_CCXT_API_KEY
CCXT_API_SECRET=REPLACE_WITH_YOUR_CCXT_API_SECRET

# ============================================================================
# Broker Integration (IBKR)
# ============================================================================
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=REPLACE_WITH_YOUR_IBKR_ACCOUNT_ID

# ============================================================================
# Risk Management
# ============================================================================
MAX_DAILY_LOSS_PERCENT=5.0
MAX_POSITION_SIZE=100000
MAX_LEVERAGE=2.0
MAX_ORDERS_PER_MINUTE=100
CIRCUIT_BREAKER_THRESHOLD=3

# ============================================================================
# Monitoring & Metrics
# ============================================================================
ENABLE_MONITORING=true
METRICS_ENABLED=true
PROMETHEUS_ENABLED=true
# ⚠️  Replace ALL values in this section before use
GRAFANA_PASSWORD=REPLACE_WITH_A_STRONG_GRAFANA_PASSWORD
GRAFANA_USER=REPLACE_WITH_YOUR_GRAFANA_USERNAME

# ============================================================================
# Database & Storage
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAXMEMORY=256mb

# ============================================================================
# ELK Stack (Elasticsearch, Logstash, Kibana)
# ============================================================================
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_ENABLED=true

# ============================================================================
# Security
# ============================================================================
# ⚠️  Replace ALL values in this section before use
API_SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET_KEY_MINIMUM_32_CHARS
API_KEY_HASH_ALGORITHM=sha256
SESSION_TIMEOUT_MINUTES=60

# ============================================================================
# Data Retention
# ============================================================================
LOG_RETENTION_DAYS=30
METRICS_RETENTION_DAYS=90
TRADE_HISTORY_RETENTION_DAYS=365

# ============================================================================
# Notifications (Optional)
# ============================================================================
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=trading-alerts
EMAIL_ALERTS_ENABLED=false
EMAIL_RECIPIENTS=trader@example.com

# ============================================================================
# Development/Debug (Never use in production)
# ============================================================================
DEBUG=false
VERBOSE_LOGGING=false
MOCK_EXCHANGE=false
TEST_MODE=false
