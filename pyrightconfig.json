{
  "pythonVersion": "3.11",
  "venvPath": ".",
  "venv": "venv",
  "include": [
    "."
  ],
  "exclude": [
    "venv",
    ".venv",
    "**/node_modules",
    "**/.*",
    "**/__pycache__",
    "build",
    "dist",
    "*.egg-info",
    "docs",
    "backups",
    "logs",
    "results",
    "cache",
    "scripts/ARCHIVED_*"
  ],
  "typeCheckingMode": "off",
  "reportMissingImports": "none",
  "reportMissingModuleSource": "none",
  "reportMissingTypeStubs": "none"
}
