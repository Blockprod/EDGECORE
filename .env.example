# Environment
EDGECORE_ENV=dev

# CCXT Exchange (Binance example)
EXCHANGE_API_KEY=your_binance_api_key
EXCHANGE_API_SECRET=your_binance_api_secret

# Interactive Brokers (if using IBKR)
IBKR_HOST=localhost
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Data
DATA_CACHE_DIR=data/cache
DATA_LOOKBACK_DAYS=730

# Slack Alerting (get from https://api.slack.com/apps)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE_ID/YOUR_CHANNEL_ID/YOUR_TOKEN

# Email Alerting (set for ERROR/CRITICAL alerts only)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your_email@gmail.com
EMAIL_SMTP_PASS=your_app_password
EMAIL_RECIPIENTS=recipient1@gmail.com,recipient2@gmail.com
