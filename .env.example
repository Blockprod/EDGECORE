# ============================================================================
# EDGECORE — Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in the values.
# NEVER commit .env to version control.
# ============================================================================

# --------------------------------------------------------------------------
# Environment (dev | test | prod)
# --------------------------------------------------------------------------
EDGECORE_ENV=dev

# --------------------------------------------------------------------------
# Interactive Brokers (IBKR) — TWS / IB Gateway
# --------------------------------------------------------------------------
IBKR_HOST=127.0.0.1
IBKR_PORT=7497                    # 7497 = TWS paper, 7496 = TWS live
IBKR_CLIENT_ID=1

# --------------------------------------------------------------------------
# Live Trading Safety
# --------------------------------------------------------------------------
# CRITICAL: Must be explicitly "true" to enable real-money trading.
ENABLE_LIVE_TRADING=false

# --------------------------------------------------------------------------
# Market Data Providers (optional)
# --------------------------------------------------------------------------
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=

# --------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs

# --------------------------------------------------------------------------
# Data
# --------------------------------------------------------------------------
DATA_CACHE_DIR=data/cache
DATA_LOOKBACK_DAYS=730

# --------------------------------------------------------------------------
# Slack Alerting (https://api.slack.com/apps)
# --------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE_ID/YOUR_CHANNEL_ID/YOUR_TOKEN

# --------------------------------------------------------------------------
# Email Alerting (SMTP — for ERROR/CRITICAL alerts)
# --------------------------------------------------------------------------
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your_email@gmail.com
EMAIL_SMTP_PASS=your_app_password
EMAIL_RECIPIENTS=recipient1@gmail.com,recipient2@gmail.com

# --------------------------------------------------------------------------
# Database (optional — PostgreSQL for production)
# --------------------------------------------------------------------------
DATABASE_URL=

# --------------------------------------------------------------------------
# Secrets Rotation
# --------------------------------------------------------------------------
SECRETS_ROTATION_ENABLED=false
SECRETS_ROTATION_INTERVAL_DAYS=90
